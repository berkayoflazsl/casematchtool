DATABASE_URL=postgresql://berkayoflaz@localhost:5432/project_law
# LLM: OpenAI OR OpenRouter (same key env; add base URL for OpenRouter)
OPENAI_API_KEY=
# OPENAI_BASE_URL=   # e.g. https://openrouter.ai/api/v1
# LLM_SERVICE_URL=  # same as base URL; alias used by other stacks
# OPENAI_MODEL=gpt-4o-mini
# LLM_MODEL=openai/gpt-4o-mini
# OpenRouter (optional, recommended on their free tier)
# OPENROUTER_HTTP_REFERER=http://127.0.0.1:3000
# OPENROUTER_APP_TITLE=CaseMatch MVP
# PORT=8000
# Ingestion
FCL_ATOM_BASE=https://caselaw.nationalarchives.gov.uk/atom.xml
# Search
SEARCH_CANDIDATE_K=50
SEARCH_FINAL_N=8
# Rate limit: sleep seconds between FCL fetches
FCL_REQUEST_SLEEP=0.15
